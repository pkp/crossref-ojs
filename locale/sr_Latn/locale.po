msgid "plugins.importexport.crossref.statusLegend"
msgstr ""
"<p>Statusi deponovanja:</p>\n"
"\t\t<p>\n"
"\t\t- Nije deponovano: nema pokušaja deponovanja za ovaj .<br />\n"
"\t\t- Aktivan: DOI je deponovan i uspešno se iščitava.<br />\n"
"\t\t- Neuspešno: Deponovanje DOI-ja nije uspelo.<br />\n"
"\t\t- Označi kao aktivno: DOI je ručno označen kao aktivan.\n"
"\t\t</p>\n"
"\t\t<p>Samo je status poslednjeg deponovanja prikazan.</p>\n"
"\t\t<p>Ukoliko deponovanje ne uspe, rešite problem i pokušajte ponovno deponovanje DOI-ja.</p>"

msgid "plugins.importexport.crossref.settings.form.depositorName.description"
msgstr ""
"Naziv organizacije koja registruje DOI-jeve. Uključuje se u deponovane "
"metapodatke i koristi se za evidentiranje ko je izvršio deponovanje."

msgid "plugins.importexport.crossref.settings.form.username.description"
msgstr ""
"Crossref korisničko ime koje će se koristiti za autentifikaciju vaših "
"deponovanja. Ako koristite lični nalog, pogledajte gore navedene upute."

msgid "plugins.importexport.crossref.register.success.warning"
msgstr ""
"Registracija je bila uspešna, ali se pojavilo sledeće upozorenje: „{$param}“."

msgid "plugins.generic.crossref.successMessage"
msgstr ""
"Metapodaci za ovu stavku su deponovani u Crossref. Za dodatne detalje "
"pogledajte predaju u <a href=\"https://doi.crossref.org/servlet/"
"submissionAdmin?sf=detail&submissionID={$submissionId}\">Crossref "
"administrativnom panelu</a>."

msgid "plugins.importexport.crossref.settings.form.validation"
msgstr ""
"Validiraj XML. Koristite ovu opciju za preuzimanje XML-a za ručnu "
"registraciju DOI-ja."

msgid "plugins.importexport.crossref.action.register"
msgstr "Deponuj"

msgid "plugins.importexport.crossref.register.error.mdsError"
msgstr ""
"Registracija nije bila u potpunosti uspešna! Server za registraciju DOI-ja "
"je vratio grešku."

msgid "plugins.importexport.crossref.status.notDeposited"
msgstr "Nije deponovano"

msgid "plugins.importexport.crossref.settings.form.onlyValidateExport"
msgstr "Samo validiraj izvoz. Ne preuzimaj fajl."

msgid "plugins.generic.crossref.description"
msgstr "Upravlja deponovanjem i izvozom Crossref metapodataka"

msgid "plugins.generic.crossref.displayName"
msgstr "Crossref dodatak za upravljanje"

msgid "plugins.importexport.crossref.settings"
msgstr "Crossref podešavanja"

msgid "plugins.generic.crossref.registrationAgency.name"
msgstr "Crossref"

msgid "plugins.importexport.crossref.settings.form.depositorEmail.description"
msgstr ""
"Adresa imejla osobe odgovorne za registraciju sadržaja u Crossref-u. "
"Uključuje se u deponovane metapodatke i koristi se za slanje imejl potvrde o "
"deponovanju."

msgid "plugins.importexport.crossref.registrationIntro"
msgstr ""
"<p>Ako želite da koristite ovaj dodatak za direktnu registraciju Digitalnih "
"identifikatora objekata (DOI) kod <a href=\"http://www.crossref.org/\""
">Crossref-a</a>, potrebno je da unesete svoje <a href=\"https://www.crossref."
"org/documentation/member-setup/account-credentials/\">Crossref akreditive "
"naloga</a> u polja za korisničko ime i lozinku ispod.</p><p>U zavisnosti od "
"vašeg Crossref članstva, postoje dva načina za unos korisničkog imena i "
"lozinke:</p><ul><li>Ako koristite organizacioni nalog, unesite svoje <a href="
"\"https://www.crossref.org/documentation/member-setup/account-credentials/#"
"00376\">deljeno korisničko ime i lozinku</a></li><li>Ako koristite <a href="
"\"https://www.crossref.org/documentation/member-setup/account-credentials/#"
"00368\">lični nalog</a>, unesite adresu imejla i ulogu u polje korisničkog "
"imena. Korisničko ime će izgledati ovako: email@example.com/role</li><li>Ako "
"ne znate ili nemate pristup svojim Crossref akreditivima, možete "
"kontaktirati <a href=\"https://support.crossref.org/\">Crossref podršku</a> "
"za pomoć. Bez akreditiva i dalje možete izvesti metapodatke u Crossref XML "
"format, ali ne možete registrovati DOI-jeve kod Crossref-a iz "
"OJS-a.</li></ul>"
